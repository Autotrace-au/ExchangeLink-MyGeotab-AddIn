{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "australiaeast"
    },
    "environmentName": {
      "value": "goa-prod"
    },
    "appName": {
      "value": "fleetbridge"
    },
    "storageAccountName": {
      "value": "replaceprodstorage"
    },
    "containerAppName": {
      "value": "replace-prod-container-app"
    },
    "keyVaultName": {
      "value": "replace-prod-keyvault"
    },
    "containerAppEnvironmentName": {
      "value": "replace-prod-container-env"
    },
    "containerRegistryName": {
      "value": "replaceprodacr"
    },
    "functionImageRepository": {
      "value": "fleetbridge-function"
    },
    "functionImageTag": {
      "value": "latest"
    },
    "containerAppMaxReplicas": {
      "value": 3
    },
    "containerCpu": {
      "value": "0.5"
    },
    "containerMemory": {
      "value": "1.0Gi"
    },
    "exchangeTenantId": {
      "value": "replace-tenant-id"
    },
    "exchangeClientId": {
      "value": "replace-client-id"
    },
    "equipmentDomain": {
      "value": "garageofawesome.com.au"
    },
    "defaultTimezone": {
      "value": "AUS Eastern Standard Time"
    },
    "myGeotabServer": {
      "value": "my.geotab.com"
    },
    "makeMailboxVisibleOnFirstSync": {
      "value": true
    }
  }
}
